#!name = QQ农场获取Code
#!desc = 自动从 QQ 农场小程序 WS 连接中提取并保存 Code。
#!icon = https://raw.githubusercontent.com/luestr/IconSet/master/App/QQ.png
[Script]
# QQ农场小程序 自动提取 code
# 在下方填写脚本的远程路径（仓库路径）
[Script]
http-request ^https://gate-obt\.nqf\.qq\.com/prod/ws script-path=https://raw.githubusercontent.com/7892798-hash/Farm/main/get-code.js, requires-body=true, timeout=10, tag=QQ农场

[MITM]
hostname = gate-obt.nqf.qq.com
